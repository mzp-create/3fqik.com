# .env.example — copy to .env.local and fill
# Postgres connection string. Local dev: create a `worldbet` role + db, e.g.
#   sudo -u postgres createuser --pwprompt worldbet && sudo -u postgres createdb -O worldbet worldbet
DATABASE_URL=postgres://worldbet:password@localhost:5432/worldbet
SESSION_SECRET=change-me-32-bytes-minimum-random
# comma-separated, position = key version (v1 first)
TICKET_SECRETS=change-me-ticket-secret-v1
APP_ORIGIN=http://localhost:3000
# Optional: free key from the-odds-api.com for the Lines Desk "Market ref"
# button (market Asian-handicap/totals reference). Unset = button shows a hint.
THE_ODDS_API_KEY=
