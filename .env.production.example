# Production env for 3fqik.com — copy to .env.local on the prod host and
# fill the two secrets. Do NOT commit the filled file.
NODE_ENV=production
# Postgres connection string (self-hosted on the box). Keep the password secret.
DATABASE_URL=postgres://worldbet:CHANGE_ME@localhost:5432/worldbet
SESSION_SECRET=change-me-run-openssl-rand-hex-32
# comma-separated, position = key version (v1 first); never remove an entry
TICKET_SECRETS=change-me-run-openssl-rand-hex-32
# public HTTPS base URL — drives Secure cookies and QR ticket links; no trailing slash
APP_ORIGIN=https://3fqik.com
# Optional: free key from the-odds-api.com for the Lines Desk "Market ref" button.
# Put the REAL key only in .env.local (gitignored) — never in this tracked file.
THE_ODDS_API_KEY=
# Admin MCP server (hermes-agent). Set both to enable the bearer auth path.
# Real token only in .env.local (gitignored). 32+ random chars; must match the
# MCP process env. BOT_ADMIN_PHONE = a role=admin player the bot acts as.
MCP_ADMIN_TOKEN=
BOT_ADMIN_PHONE=
